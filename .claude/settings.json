{
  "permissions": {
    "allow": [
      "Bash(ghx:*)",
      "Bash(rg:*)",
      "Bash(readlink:*)",
      "Bash(mkdir:*)",
      "Bash(npx:*)",
      "Bash(bun:*)",
      "Bash(tsx:*)",
      "Bash(find:*)",
      "Bash(mv:*)",
      "Bash(grep:*)",
      "Bash(ls:*)",
      "Bash(cp:*)",
      "Bash(touch:*)",
      "Bash(tree:*)",
      "Bash(wc:*)",
      "Bash(git:*)",
      "Edit",
      "Write",
      "WebSearch",
      "WebFetch(domain:tanstack.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:ui.shadcn.com)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Read(./**/credentials.json)",
      "Read(./**/credentials.*.json)",
      "Read(./**/*.key)",
      "Read(./**/*.pem)",
      "Read(./**/*.cer)",
      "Bash(tee:*)",
      "Bash(sudo:*)",
      "Bash(chown:*)",
      "Bash(chmod:*)",
      "Bash(ssh:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean:*)",
      "Bash(git checkout -- :*)",
      "Bash(git restore:*)",
      "Bash(git branch -D:*)",
      "Bash(git rebase:*)",
      "Bash(git stash drop:*)"
    ],
    "ask": [
      "Bash(rm:*)",
      "Bash(git merge:*)",
      "Bash(git cherry-pick:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "CMD=$(jq -r '.tool_input.command // empty'); if [ \"$CMD\" = 'rm -rf /' ]; then echo 'BLOCKED: rm -rf / is not allowed' >&2; exit 2; fi",
            "name": "block-rm-rf-root"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "FILE_PATHS=$(jq -r '.tool_input.file_path // empty' | tr '\\n' ' '); [ -n \"$FILE_PATHS\" ] && for FILE in $FILE_PATHS; do if [[ \"$FILE\" =~ \\.(ts|tsx|js|jsx|mjs|cjs|json|md|yaml)$ ]] && [[ ! \"$FILE\" =~ (CLAUDE|claude)\\.md$ ]]; then bunx prettier --write \"$FILE\" 2>/dev/null || true; fi; done",
            "async": true,
            "name": "prettier-autoformat"
          },
          {
            "type": "command",
            "command": "FILE_PATHS=$(jq -r '.tool_input.file_path // empty' | tr '\\n' ' '); [ -n \"$FILE_PATHS\" ] && for FILE in $FILE_PATHS; do if [[ \"$FILE\" =~ \\.(ts|tsx|js|jsx|mjs|cjs)$ ]] && [[ ! \"$FILE\" =~ (CLAUDE|claude)\\.md$ ]]; then bunx oxlint --fix \"$FILE\" 2>/dev/null || true; fi; done",
            "name": "oxlint-autofix"
          }
        ]
      }
    ]
  },
  "sandbox": {
    "enabled": false,
    "autoAllowBashIfSandboxed": true,
    "allowUnsandboxedCommands": false,
    "network": {
      "allowManagedDomainsOnly": true,
      "allowedDomains": [
        "https://code.claude.com",
        "https://github.com",
        "https://ui.shadcn.com",
        "https://tanstack.com"
      ]
    },
    "filesystem": {
      "denyRead": [".env", ".env.*"],
      "denyWrite": [".env*"]
    }
  }
}
