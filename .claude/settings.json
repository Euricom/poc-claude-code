{
  "permissions": {
    "allow": [
      "Bash(gh pr list:*)",
      "Bash(ghx:*)",
      "Bash(readlink:*)",
      "Bash(mkdir:*)",
      "Bash(tsx:*)",
      "Bash(touch:*)",
      "Bash(tree:*)",
      "Bash(wc:*)",
      "Bash(ls:*)",
      "Bash(which:*)",
      "Bash(node -e:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git add:*)",
      "Bash(git branch:*)",
      "Bash(git switch:*)",
      "Bash(git checkout -b:*)",
      "Bash(git stash:*)",
      "Bash(git show:*)",
      "Bash(git tag:*)",
      "Bash(git remote:*)",
      "Bash(git rev-parse:*)",
      "Bash(bun run lint:*)",
      "Bash(bun run build:*)",
      "Bash(bun run start:*)",
      "Bash(bun run typecheck:*)",
      "Edit",
      "Write",
      "WebSearch",
      "WebFetch(domain:tanstack.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:ui.shadcn.com)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(*secret*)",
      "Bash(tee:*)",
      "Bash(sudo:*)",
      "Bash(chown:*)",
      "Bash(chmod:*)",
      "Bash(env:*)",
      "Bash(printenv:*)",
      "Bash(export:*)",
      "Bash(open:*)",
      "Bash(base64:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean:*)",
      "Bash(git checkout -- :*)",
      "Bash(git restore:*)",
      "Bash(git branch -D:*)",
      "Bash(git rebase:*)",
      "Bash(git stash drop:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(kill:*)",
      "Bash(pkill:*)",
      "Bash(killall:*)",
      "Bash(docker:*)",
      "Bash(brew:*)"
    ],
    "ask": [
      "Bash(rm:*)",
      "Bash(mv:*)",
      "Bash(cp:*)",
      "Bash(npx:*)",
      "Bash(bun:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(git:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "CMD=$(jq -r '.tool_input.command // empty'); if echo \"$CMD\" | grep -qE '^rm\\s+.*-[a-z]*r[a-z]*f|^rm\\s+.*-[a-z]*f[a-z]*r|^rm\\s+--recursive|^rm\\s+-r\\s'; then echo 'BLOCKED: recursive delete requires explicit approval. Use non-recursive rm or specify exact paths.' >&2; exit 2; fi",
            "name": "block-rm-rf"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "FILE_PATHS=$(jq -r '.tool_input.file_path // empty' | tr '\\n' ' '); [ -n \"$FILE_PATHS\" ] && for FILE in $FILE_PATHS; do if [[ \"$FILE\" =~ \\.(ts|tsx|js|jsx|mjs|cjs|json|md|yaml)$ ]] && [[ ! \"$FILE\" =~ (CLAUDE|claude)\\.md$ ]]; then bunx prettier --write \"$FILE\" 2>/dev/null || true; fi; done",
            "async": true,
            "name": "prettier-autoformat"
          },
          {
            "type": "command",
            "command": "FILE_PATHS=$(jq -r '.tool_input.file_path // empty' | tr '\\n' ' '); [ -n \"$FILE_PATHS\" ] && for FILE in $FILE_PATHS; do if [[ \"$FILE\" =~ \\.(ts|tsx|js|jsx|mjs|cjs)$ ]] && [[ ! \"$FILE\" =~ (CLAUDE|claude)\\.md$ ]]; then bunx oxlint --fix \"$FILE\" 2>/dev/null || true; fi; done",
            "name": "oxlint-autofix"
          }
        ]
      }
    ]
  }
}
