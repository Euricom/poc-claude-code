{
  "hooks": {
    // http base hook
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:3000/audit",
            "name": "audit-bash-commands"
          }
        ]
      }
    ]
  },
  // sandbox configuration
  "sandbox": {
    "enabled": false,
    "autoAllowBashIfSandboxed": false,
    "allowUnsandboxedCommands": false,
    "network": {
      "allowManagedDomainsOnly": true,
      "allowedDomains": [
        "https://github.com",
        "https://ui.shadcn.com",
        "https://tanstack.com"
      ]
    },
    "filesystem": {
      "denyRead": [".env", ".env.*", ".npmrc", "*secret*"],
      "denyWrite": [".env*", ".npmrc", "*secret*"]
    }
  }
}
